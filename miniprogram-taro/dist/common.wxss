.tab-bar{-webkit-align-items:center;bottom:0;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:row;-ms-flex-direction:row;flex-direction:row;left:0;position:fixed;right:0;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-around;-ms-flex-pack:distribute;backdrop-filter:var(--glass-blur);-webkit-backdrop-filter:var(--glass-blur);background-color:hsla(0,0%,100%,.75);border-top:var(--glass-border);height:100rpx;justify-content:space-around;z-index:999}.tab-bar__item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;padding:var(--spacing-xs) 0;-webkit-transition:opacity .2s;transition:opacity .2s}.tab-bar__item:active{opacity:.7}.tab-bar__item--active .tab-bar__text{color:var(--color-primary)}.tab-bar__icon{height:48rpx;margin-bottom:4rpx;width:48rpx}.tab-bar__text{color:var(--color-text-secondary);font-size:var(--font-size-xs);-webkit-transition:color .2s;transition:color .2s}