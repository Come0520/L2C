.tab-bar{-webkit-align-items:center;bottom:0;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:row;-ms-flex-direction:row;flex-direction:row;left:0;position:fixed;right:0;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-around;-ms-flex-pack:distribute;backdrop-filter:saturate(180%) blur(20rpx);-webkit-backdrop-filter:saturate(180%) blur(20rpx);background-color:hsla(0,0%,100%,.85);border-top:1rpx solid rgba(60,60,67,.1);height:100rpx;justify-content:space-around;padding-bottom:env(safe-area-inset-bottom);z-index:999}.tab-bar__item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;padding:8rpx 0;-webkit-transition:opacity .2s;transition:opacity .2s}.tab-bar__item:active{opacity:.7}.tab-bar__item--active .tab-bar__text{color:#0071e3}.tab-bar__icon{height:48rpx;margin-bottom:4rpx;width:48rpx}.tab-bar__text{color:#6e6e73;font-size:22rpx;-webkit-transition:color .2s;transition:color .2s}