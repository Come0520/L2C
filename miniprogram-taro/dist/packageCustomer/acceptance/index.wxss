.acceptance-page{background-color:#f2f2f7;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh}.acceptance-page .content-scroll{-webkit-flex:1;-ms-flex:1;flex:1;height:100vh;padding-bottom:140rpx}.acceptance-page .page-header{padding:32rpx 24rpx 24rpx;text-align:center}.acceptance-page .page-header .title{color:#1d1d1f;display:block;font-size:40rpx;font-weight:700;margin-bottom:8rpx}.acceptance-page .page-header .subtitle{color:#6e6e73;display:block;font-size:24rpx}.acceptance-page .section-card{background-color:#fff;border-radius:28rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:0 24rpx 24rpx;padding:24rpx}.acceptance-page .section-card .section-title{color:#1d1d1f;display:block;font-size:30rpx;font-weight:600;margin-bottom:24rpx}.acceptance-page .photo-grid{display:grid;gap:16rpx;grid-template-columns:repeat(4,1fr)}.acceptance-page .photo-grid .photo-item{aspect-ratio:1;border-radius:16rpx;overflow:hidden;position:relative;width:100%}.acceptance-page .photo-grid .photo-item .img{height:100%;width:100%}.acceptance-page .photo-grid .photo-item .remove-btn{-webkit-align-items:center;background:rgba(0,0,0,.5);color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:36rpx;position:absolute;right:0;top:0;width:36rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;border-bottom-left-radius:16rpx;font-size:20rpx;justify-content:center}.acceptance-page .photo-grid .upload-btn{-webkit-align-items:center;aspect-ratio:1;background-color:#f8f8f8;border:1rpx dashed rgba(60,60,67,.1);border-radius:16rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;width:100%;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.acceptance-page .photo-grid .upload-btn .plus{color:#aeaeb2;font-size:40rpx;line-height:1;margin-bottom:4rpx}.acceptance-page .photo-grid .upload-btn .tip{color:#6e6e73;font-size:20rpx}.acceptance-page .canvas-container{background-color:#f8f8f8;border:1rpx solid rgba(60,60,67,.1);border-radius:20rpx;height:440rpx;overflow:hidden;position:relative;width:100%}.acceptance-page .canvas-container .sign-canvas{height:100%;left:0;position:absolute;top:0;width:100%;z-index:10}.acceptance-page .canvas-container .canvas-placeholder{color:#aeaeb2;font-size:32rpx;font-weight:500;left:50%;letter-spacing:4rpx;pointer-events:none;position:absolute;top:50%;-webkit-transform:translate(-50%,-50%);-ms-transform:translate(-50%,-50%);transform:translate(-50%,-50%);z-index:1}.acceptance-page .clear-row{margin-top:16rpx;text-align:right}.acceptance-page .clear-row .clear-text{color:#6e6e73;font-size:24rpx;padding:8rpx 0}.acceptance-page .clear-row .clear-text:active{opacity:.6}.acceptance-page .agreements{padding:0 48rpx;text-align:center}.acceptance-page .agreements .text{color:#6e6e73;font-size:22rpx;line-height:1.5}.acceptance-page .bottom-action-bar{background-color:#fff;bottom:0;-webkit-box-shadow:0 -2rpx 10rpx rgba(0,0,0,.05);box-shadow:0 -2rpx 10rpx rgba(0,0,0,.05);left:0;padding:16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));position:fixed;right:0;z-index:100}.acceptance-page .bottom-action-bar .btn-primary{-webkit-align-items:center;background-color:#0071e3;border-radius:100rpx;color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:88rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:32rpx;font-weight:600;justify-content:center}.acceptance-page .bottom-action-bar .btn-primary:active{opacity:.8}.acceptance-page .bottom-action-bar .btn-primary.disabled{background-color:rgba(0,113,227,.4);color:hsla(0,0%,100%,.8)}