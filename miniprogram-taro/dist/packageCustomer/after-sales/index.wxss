.after-sales-page{background-color:#f2f2f7;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh}.after-sales-page .content-scroll{-webkit-flex:1;-ms-flex:1;flex:1;height:100vh;padding-bottom:160rpx}.after-sales-page .page-header{padding:32rpx 24rpx 24rpx;text-align:center}.after-sales-page .page-header .title{color:#1d1d1f;display:block;font-size:40rpx;font-weight:700;margin-bottom:8rpx}.after-sales-page .page-header .subtitle{color:#6e6e73;display:block;font-size:24rpx}.after-sales-page .section-card{background-color:#fff;border-radius:28rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:0 24rpx 24rpx;padding:24rpx}.after-sales-page .section-card .section-title{color:#1d1d1f;display:block;font-size:30rpx;font-weight:600;margin-bottom:24rpx}.after-sales-page .section-card .section-title .required{color:#ff3b30;margin-left:4rpx}.after-sales-page .form-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-bottom:1rpx solid rgba(60,60,67,.1);min-height:88rpx}.after-sales-page .form-item:last-child{border-bottom:none}.after-sales-page .form-item .label{color:#1d1d1f;font-size:30rpx;width:200rpx}.after-sales-page .form-item .label .required{color:#ff3b30;margin-left:4rpx}.after-sales-page .form-item .input-field{color:#1d1d1f;-webkit-flex:1;-ms-flex:1;flex:1;font-size:30rpx;text-align:right}.after-sales-page .form-item .picker-value{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-justify-content:flex-end;-ms-flex-pack:end;-webkit-align-items:center;justify-content:flex-end;-ms-flex-align:center;align-items:center;color:#1d1d1f;font-size:30rpx}.after-sales-page .form-item .picker-value.placeholder{color:#aeaeb2}.after-sales-page .form-item .picker-value .arrow{color:#aeaeb2;font-family:monospace;margin-left:8rpx}.after-sales-page .textarea-wrapper{background-color:#f8f8f8;border:1rpx solid rgba(60,60,67,.1);border-radius:20rpx;padding:16rpx;position:relative}.after-sales-page .textarea-wrapper .desc-textarea{color:#1d1d1f;font-size:30rpx;height:200rpx;line-height:1.5;width:100%}.after-sales-page .textarea-wrapper .word-count{bottom:16rpx;color:#aeaeb2;font-size:20rpx;position:absolute;right:16rpx}.after-sales-page .photo-section .photo-grid{display:grid;gap:16rpx;grid-template-columns:repeat(4,1fr)}.after-sales-page .photo-section .photo-grid .photo-item{aspect-ratio:1;border-radius:16rpx;overflow:hidden;position:relative;width:100%}.after-sales-page .photo-section .photo-grid .photo-item .img{height:100%;width:100%}.after-sales-page .photo-section .photo-grid .photo-item .remove-btn{-webkit-align-items:center;background:rgba(0,0,0,.5);color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:36rpx;position:absolute;right:0;top:0;width:36rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;border-bottom-left-radius:16rpx;font-size:20rpx;justify-content:center}.after-sales-page .photo-section .photo-grid .upload-btn{-webkit-align-items:center;aspect-ratio:1;background-color:#f8f8f8;border:1rpx dashed rgba(60,60,67,.1);border-radius:16rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;width:100%;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.after-sales-page .photo-section .photo-grid .upload-btn .plus{color:#aeaeb2;font-size:40rpx;line-height:1;margin-bottom:4rpx}.after-sales-page .photo-section .photo-grid .upload-btn .tip{color:#6e6e73;font-size:20rpx}.after-sales-page .bottom-action-bar{background-color:#fff;bottom:0;-webkit-box-shadow:0 -2rpx 10rpx rgba(0,0,0,.05);box-shadow:0 -2rpx 10rpx rgba(0,0,0,.05);left:0;padding:16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));position:fixed;right:0;z-index:100}.after-sales-page .bottom-action-bar .btn-primary{-webkit-align-items:center;background-color:#0071e3;border-radius:100rpx;color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:88rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:32rpx;font-weight:600;justify-content:center}.after-sales-page .bottom-action-bar .btn-primary:active{opacity:.8}.after-sales-page .bottom-action-bar .btn-primary.disabled{background-color:rgba(0,113,227,.4);color:hsla(0,0%,100%,.8)}