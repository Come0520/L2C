.quote-sign-page{background-color:#fff;-webkit-box-sizing:border-box;box-sizing:border-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh;padding:32rpx 24rpx}.quote-sign-page .header-info{margin-bottom:24rpx;text-align:center}.quote-sign-page .header-info .title{color:#1d1d1f;display:block;font-size:36rpx;font-weight:600;margin-bottom:8rpx}.quote-sign-page .header-info .subtitle{color:#6e6e73;display:block;font-size:24rpx}.quote-sign-page .canvas-container{background-color:#f2f2f7;border:1rpx solid rgba(60,60,67,.1);border-radius:28rpx;-webkit-flex:1;-ms-flex:1;flex:1;margin:24rpx 0;overflow:hidden;position:relative}.quote-sign-page .canvas-container .sign-canvas{height:100%;left:0;position:absolute;top:0;width:100%;z-index:10}.quote-sign-page .canvas-container .canvas-placeholder{color:#aeaeb2;font-size:32rpx;font-weight:500;left:50%;letter-spacing:4rpx;pointer-events:none;position:absolute;top:50%;-webkit-transform:translate(-50%,-50%);-ms-transform:translate(-50%,-50%);transform:translate(-50%,-50%);z-index:1}.quote-sign-page .agreements{margin-bottom:48rpx;padding:0 16rpx;text-align:center}.quote-sign-page .agreements .text{color:#6e6e73;font-size:22rpx;line-height:1.6}.quote-sign-page .agreements .link{color:#0071e3;font-size:22rpx}.quote-sign-page .action-bar{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:24rpx;padding-bottom:env(safe-area-inset-bottom)}.quote-sign-page .action-bar .btn{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;height:96rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;border-radius:100rpx;font-size:32rpx;font-weight:600;justify-content:center;margin:0}.quote-sign-page .action-bar .btn::after{border:none}.quote-sign-page .action-bar .btn:active{opacity:.8}.quote-sign-page .action-bar .btn-outline{background-color:transparent;border:1rpx solid rgba(60,60,67,.1);color:#1d1d1f}.quote-sign-page .action-bar .btn-primary{background-color:#0071e3;color:#fff}.quote-sign-page .action-bar .btn-primary.disabled{background-color:rgba(0,113,227,.4);color:hsla(0,0%,100%,.8)}