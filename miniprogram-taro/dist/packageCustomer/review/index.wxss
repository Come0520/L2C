.review-page{background-color:#f2f2f7;min-height:100vh;padding-bottom:160rpx}.review-page .page-header{padding:32rpx 24rpx 24rpx;text-align:center}.review-page .page-header .title{color:#1d1d1f;display:block;font-size:40rpx;font-weight:700;margin-bottom:8rpx}.review-page .page-header .subtitle{color:#6e6e73;display:block;font-size:24rpx}.review-page .section-card{background-color:#fff;border-radius:28rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:0 24rpx 24rpx;padding:24rpx}.review-page .section-card .section-title{color:#1d1d1f;display:block;font-size:30rpx;font-weight:600;margin-bottom:24rpx}.review-page .rating-section{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;padding-bottom:48rpx;padding-top:48rpx}.review-page .rating-section .section-title{margin-bottom:32rpx}.review-page .rating-section .stars-container{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:16rpx;margin-bottom:16rpx}.review-page .rating-section .stars-container .star{color:#e5e5ea;font-size:80rpx;line-height:1;-webkit-transition:color .3s;transition:color .3s}.review-page .rating-section .stars-container .star.active{color:#ff9f0a}.review-page .rating-section .rating-desc{color:#6e6e73;font-size:24rpx;font-weight:500;height:40rpx}.review-page .content-section .textarea-wrapper{background-color:#f8f8f8;border:1rpx solid rgba(60,60,67,.1);border-radius:20rpx;padding:16rpx;position:relative}.review-page .content-section .textarea-wrapper .review-textarea{color:#1d1d1f;font-size:30rpx;height:240rpx;line-height:1.5;width:100%}.review-page .content-section .textarea-wrapper .textarea-placeholder{color:#aeaeb2}.review-page .content-section .textarea-wrapper .word-count{bottom:16rpx;color:#aeaeb2;font-size:20rpx;position:absolute;right:16rpx}.review-page .photo-section .photo-grid{display:grid;gap:16rpx;grid-template-columns:repeat(4,1fr)}.review-page .photo-section .photo-grid .photo-item{aspect-ratio:1;border-radius:16rpx;overflow:hidden;position:relative;width:100%}.review-page .photo-section .photo-grid .photo-item .img{height:100%;width:100%}.review-page .photo-section .photo-grid .photo-item .remove-btn{-webkit-align-items:center;background:rgba(0,0,0,.5);color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:36rpx;position:absolute;right:0;top:0;width:36rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;border-bottom-left-radius:16rpx;font-size:20rpx;justify-content:center}.review-page .photo-section .photo-grid .upload-btn{-webkit-align-items:center;aspect-ratio:1;background-color:#f8f8f8;border:1rpx dashed rgba(60,60,67,.1);border-radius:16rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;width:100%;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.review-page .photo-section .photo-grid .upload-btn .plus{color:#aeaeb2;font-size:40rpx;line-height:1;margin-bottom:4rpx}.review-page .photo-section .photo-grid .upload-btn .tip{color:#6e6e73;font-size:20rpx}.review-page .bottom-action-bar{background-color:#fff;bottom:0;-webkit-box-shadow:0 -2rpx 10rpx rgba(0,0,0,.05);box-shadow:0 -2rpx 10rpx rgba(0,0,0,.05);left:0;padding:16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));position:fixed;right:0;z-index:100}.review-page .bottom-action-bar .btn-primary{-webkit-align-items:center;background-color:#0071e3;border-radius:100rpx;color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:88rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:32rpx;font-weight:600;justify-content:center}.review-page .bottom-action-bar .btn-primary:active{opacity:.8}.review-page .bottom-action-bar .btn-primary.disabled{background-color:rgba(0,113,227,.4);color:hsla(0,0%,100%,.8)}