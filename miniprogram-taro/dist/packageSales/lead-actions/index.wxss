er .title{color:#ff3b30}.lead-actions-page .section .btn-primary{-webkit-align-items:center;background-color:#0071e3;border-radius:28rpx;color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;height:96rpx;margin:32rpx 24rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:30rpx;font-weight:500;justify-content:center}.lead-actions-page .section .btn-primary::after{border:none}.lead-actions-page .section .btn-primary:active{opacity:.8}