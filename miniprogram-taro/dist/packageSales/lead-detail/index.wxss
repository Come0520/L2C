.lead-detail-page{background-color:#f2f2f7;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh}.lead-detail-page .detail-scroll{-webkit-flex:1;-ms-flex:1;flex:1;padding-bottom:200rpx}.lead-detail-page .card{background-color:#fff;border-radius:28rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:24rpx;padding:32rpx}.lead-detail-page .info-card .lead-name{color:#1d1d1f;display:block;font-size:36rpx;font-weight:700;margin-bottom:8rpx}.lead-detail-page .info-card .lead-phone{color:#0071e3;display:block;font-size:32rpx;font-weight:500;margin-bottom:24rpx}.lead-detail-page .info-card .info-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;margin-top:16rpx}.lead-detail-page .info-card .info-row .info-label{color:#6e6e73;font-size:30rpx}.lead-detail-page .info-card .info-row .info-value{color:#1d1d1f;font-size:30rpx;font-weight:500}.lead-detail-page .info-card .info-row .info-value.status{color:#ff9500}.lead-detail-page .activities-section .section-header{-webkit-align-items:center;margin-bottom:16rpx;margin-top:32rpx;padding:0 24rpx;-ms-flex-align:center;align-items:center}.lead-detail-page .activities-section .section-header .section-title{color:#1d1d1f;font-size:32rpx;font-weight:600}.lead-detail-page .activities-section .section-header .btn-add-activity{color:#0071e3;font-size:24rpx;font-weight:500}.lead-detail-page .activities-section .activity-item .activity-type{background-color:#6e6e73;border-radius:16rpx;color:#fff;font-size:24rpx;padding:4rpx 12rpx}.lead-detail-page .activities-section .activity-item .activity-date{color:#aeaeb2;font-size:22rpx}.lead-detail-page .activities-section .activity-item .activity-content{color:#1d1d1f;display:block;font-size:30rpx;line-height:1.5;margin-top:16rpx}.lead-detail-page .activities-section .empty{padding:48rpx 0}.lead-detail-page .activities-section .empty .empty-text{color:#aeaeb2;font-size:24rpx}.lead-detail-page .bottom-bar{background-color:#fff;bottom:0;-webkit-box-shadow:0 -4rpx 16rpx rgba(0,0,0,.05);box-shadow:0 -4rpx 16rpx rgba(0,0,0,.05);display:-webkit-flex;display:-ms-flexbox;display:flex;gap:24rpx;left:0;padding:24rpx;position:fixed;right:0;z-index:100}.lead-detail-page .bottom-bar .btn{-webkit-align-items:center;border-radius:100rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;height:88rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:30rpx;font-weight:500;justify-content:center}.lead-detail-page .bottom-bar .btn:active{opacity:.8}.lead-detail-page .bottom-bar .btn.btn-outline{border:1rpx solid rgba(0,0,0,.1);color:#1d1d1f}.lead-detail-page .bottom-bar .btn.btn-primary{background-color:#0071e3;color:#fff;-webkit-flex:2;-ms-flex:2;flex:2}.lead-detail-page .bottom-bar .safe-bottom-space{bottom:0;height:env(safe-area-inset-bottom);left:0;position:absolute;right:0}