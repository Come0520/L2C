.measure-review-page{background-color:#f2f2f7;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh}.measure-review-page .content-scroll{-webkit-flex:1;-ms-flex:1;flex:1;padding-bottom:200rpx}.measure-review-page .warning-banner{-webkit-align-items:center;background-color:rgba(0,113,227,.1);display:-webkit-flex;display:-ms-flexbox;display:flex;padding:24rpx 32rpx;-ms-flex-align:center;align-items:center}.measure-review-page .warning-banner .icon{font-size:32rpx;margin-right:12rpx}.measure-review-page .warning-banner .text{color:#0071e3;-webkit-flex:1;-ms-flex:1;flex:1;font-size:24rpx;font-weight:500}.measure-review-page .card{background-color:#fff;border-radius:28rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:24rpx;padding:24rpx}.measure-review-page .card .title{border-bottom:1rpx solid rgba(0,0,0,.03);color:#1d1d1f;display:block;font-size:30rpx;font-weight:600;margin-bottom:24rpx;padding-bottom:16rpx}.measure-review-page .card .row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center;margin-bottom:16rpx}.measure-review-page .card .row .label{color:#6e6e73;font-size:24rpx}.measure-review-page .card .row .val{color:#1d1d1f;font-size:30rpx;font-weight:500}.measure-review-page .card .row .val.txt-primary{color:#0071e3}.measure-review-page .data-card .note-box{background-color:#f9f9f9;border-radius:20rpx;margin-top:24rpx;padding:24rpx}.measure-review-page .data-card .note-box .lbl{color:#6e6e73;display:block;font-size:24rpx;margin-bottom:8rpx}.measure-review-page .data-card .note-box .txt{color:#1d1d1f;font-size:30rpx;line-height:1.5}.measure-review-page .media-card .img-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:16rpx}.measure-review-page .media-card .img-list .img{background-color:#f0f0f0;border-radius:20rpx;height:160rpx;width:160rpx}.measure-review-page .bottom-bar{background-color:#fff;bottom:0;-webkit-box-shadow:0 -4rpx 16rpx rgba(0,0,0,.05);box-shadow:0 -4rpx 16rpx rgba(0,0,0,.05);display:-webkit-flex;display:-ms-flexbox;display:flex;gap:24rpx;left:0;padding:24rpx;position:fixed;right:0;z-index:100}.measure-review-page .bottom-bar .btn{-webkit-align-items:center;border-radius:100rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;height:96rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:30rpx;font-weight:600;justify-content:center}.measure-review-page .bottom-bar .btn:active{opacity:.8}.measure-review-page .bottom-bar .btn.btn-outline{border:1rpx solid rgba(0,0,0,.1);color:#1d1d1f}.measure-review-page .bottom-bar .btn.btn-primary{background-color:#0071e3;color:#fff;-webkit-flex:1.5;-ms-flex:1.5;flex:1.5}.measure-review-page .bottom-bar .safe-bottom-space{bottom:0;height:env(safe-area-inset-bottom);left:0;position:absolute;right:0}