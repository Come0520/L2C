.share-hub-page{background-color:#f2f2f7;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh}.share-hub-page .header-stats{background-color:#0071e3;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-around;padding:48rpx 24rpx 32rpx;-ms-flex-pack:distribute;border-bottom-left-radius:40rpx;border-bottom-right-radius:40rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);justify-content:space-around}.share-hub-page .header-stats .stat-box{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center}.share-hub-page .header-stats .stat-box .val{color:#fff;font-family:SF Pro Display,sans-serif;font-size:40rpx;font-weight:700;margin-bottom:8rpx}.share-hub-page .header-stats .stat-box .lbl{color:hsla(0,0%,100%,.8);font-size:24rpx}.share-hub-page .material-list{-webkit-flex:1;-ms-flex:1;flex:1;padding:24rpx 0}.share-hub-page .material-list .card{background-color:#fff;border-radius:28rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:0 24rpx 24rpx;overflow:hidden}.share-hub-page .material-list .material-card{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column}.share-hub-page .material-list .material-card .cover-img{background-color:#f0f0f0;height:300rpx;width:100%}.share-hub-page .material-list .material-card .info-area{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;padding:24rpx;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center}.share-hub-page .material-list .material-card .info-area .title{color:#1d1d1f;display:block;font-size:32rpx;font-weight:600;margin-bottom:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.share-hub-page .material-list .material-card .info-area .metrics{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center}.share-hub-page .material-list .material-card .info-area .metrics .tag{background-color:rgba(0,113,227,.1);border-radius:8rpx;color:#0071e3;font-size:20rpx;margin-right:12rpx;padding:2rpx 12rpx}.share-hub-page .material-list .material-card .info-area .metrics .num{color:#6e6e73;font-size:22rpx}.share-hub-page .material-list .material-card .info-area .btn-share{background-color:#ff9500;border-radius:100rpx;color:#fff;font-size:24rpx;font-weight:500;height:64rpx;line-height:64rpx;margin:0;padding:0 32rpx}.share-hub-page .material-list .material-card .info-area .btn-share::after{border:none}.share-hub-page .material-list .material-card .info-area .btn-share:active{opacity:.8}