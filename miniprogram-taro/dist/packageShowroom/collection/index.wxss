d-grid .card .card-body{padding:24rpx}.collection-page .items-list .card-grid .card .card-body .meta{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;margin-bottom:8rpx}.collection-page .items-list .card-grid .card .card-body .meta .badge{border-radius:16rpx;font-size:20rpx;padding:2rpx 8rpx}.collection-page .items-list .card-grid .card .card-body .meta .badge--article{background:rgba(64,158,255,.15);color:#409eff}.collection-page .items-list .card-grid .card .card-body .meta .badge--case{background:rgba(103,194,58,.15);color:#34c759}.collection-page .items-list .card-grid .card .card-body .meta .badge--product{background:rgba(230,180,80,.15);color:#0071e3}.collection-page .items-list .card-grid .card .card-body .meta .price{color:#ff3b30;font-size:28rpx;font-weight:600}.collection-page .items-list .card-grid .card .card-body .title{color:#1d1d1f;display:-webkit-box;font-size:30rpx;font-weight:600;-webkit-line-clamp:2;margin-bottom:4rpx;-webkit-box-orient:vertical;overflow:hidden}.collection-page .items-list .card-grid .card .card-body .description{color:#6e6e73;font-size:24rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}