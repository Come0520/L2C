.favorites-page{background-color:#f2f2f7;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;height:100vh}.favorites-page .tabs-header{background-color:#fff;border-bottom:1rpx solid rgba(60,60,67,.1);display:-webkit-flex;display:-ms-flexbox;display:flex;height:88rpx}.favorites-page .tabs-header .tab-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;position:relative}.favorites-page .tabs-header .tab-item .tab-text{color:#6e6e73;font-size:30rpx}.favorites-page .tabs-header .tab-item.active .tab-text{color:#0071e3;font-weight:600}.favorites-page .tabs-header .tab-item .tab-line{background-color:#0071e3;border-radius:4rpx;bottom:0;height:6rpx;position:absolute;width:48rpx}.favorites-page .list-scroll{-webkit-flex:1;-ms-flex:1;flex:1;height:0}.favorites-page .list-scroll .favorites-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:24rpx;padding:24rpx}.favorites-page .list-scroll .favorites-list .favorite-item{background-color:#fff;border-radius:20rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:24rpx;padding:24rpx}.favorites-page .list-scroll .favorites-list .favorite-item .item-cover{background-color:#f2f2f7;border-radius:16rpx;-webkit-flex-shrink:0;height:150rpx;width:200rpx;-ms-flex-negative:0;flex-shrink:0}.favorites-page .list-scroll .favorites-list .favorite-item .item-info{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between}.favorites-page .list-scroll .favorites-list .favorite-item .item-info .item-title{color:#1d1d1f;display:-webkit-box;font-size:30rpx;font-weight:500;-webkit-line-clamp:2;line-clamp:2;-webkit-box-orient:vertical;line-height:1.4;overflow:hidden}.favorites-page .list-scroll .favorites-list .favorite-item .item-info .item-bottom{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center}.favorites-page .list-scroll .favorites-list .favorite-item .item-info .item-bottom .item-desc{color:#0071e3;font-size:24rpx}.favorites-page .list-scroll .favorites-list .favorite-item .item-info .item-bottom .item-date{color:#aeaeb2;font-size:20rpx}.flex-center{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;height:100%;justify-content:center}.empty-state,.loading-state{color:#aeaeb2;font-size:24rpx}