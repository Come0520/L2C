.liability-page{background-color:#f2f2f7;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;height:100vh}.liability-page .content-scroll{-webkit-flex:1;-ms-flex:1;flex:1;padding-bottom:200rpx}.liability-page .warning-banner{-webkit-align-items:flex-start;background-color:rgba(255,59,48,.1);display:-webkit-flex;display:-ms-flexbox;display:flex;padding:24rpx 32rpx;-ms-flex-align:start;align-items:flex-start}.liability-page .warning-banner .icon{font-size:32rpx;margin-right:12rpx;margin-top:4rpx}.liability-page .warning-banner .text{color:#ff3b30;-webkit-flex:1;-ms-flex:1;flex:1;font-size:24rpx;font-weight:500;line-height:1.5}.liability-page .card{background-color:#fff;border-radius:28rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:24rpx;padding:32rpx}.liability-page .liability-card .card-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center;border-bottom:1rpx dashed rgba(60,60,67,.1);margin-bottom:24rpx;padding-bottom:16rpx}.liability-page .liability-card .card-header .title{color:#1d1d1f;font-size:32rpx;font-weight:700}.liability-page .liability-card .card-header .date{color:#aeaeb2;font-size:24rpx}.liability-page .liability-card .info-list .info-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center;margin-bottom:16rpx}.liability-page .liability-card .info-list .info-row .label{color:#6e6e73;font-size:30rpx}.liability-page .liability-card .info-list .info-row .value{color:#1d1d1f;font-size:30rpx;font-weight:500}.liability-page .liability-card .info-list .info-row.penalty{border-top:1rpx solid rgba(0,0,0,.03);margin-top:24rpx;padding-top:24rpx}.liability-page .liability-card .info-list .info-row.penalty .amount{color:#ff3b30;font-family:SF Pro Display,sans-serif;font-size:36rpx;font-weight:700}.liability-page .liability-card .reason-section{background-color:#f8f8f8;border-radius:20rpx;margin-top:32rpx;padding:24rpx}.liability-page .liability-card .reason-section .reason-label{color:#6e6e73;display:block;font-size:24rpx;margin-bottom:8rpx}.liability-page .liability-card .reason-section .reason-text{color:#1d1d1f;font-size:30rpx;line-height:1.5}.liability-page .tips-card .title{color:#1d1d1f;display:block;font-size:30rpx;font-weight:600;margin-bottom:16rpx}.liability-page .tips-card .desc{color:#6e6e73;display:block;font-size:24rpx;line-height:1.6;margin-bottom:8rpx}.liability-page .bottom-bar{background-color:#fff;bottom:0;-webkit-box-shadow:0 -4rpx 16rpx rgba(0,0,0,.05);box-shadow:0 -4rpx 16rpx rgba(0,0,0,.05);display:-webkit-flex;display:-ms-flexbox;display:flex;gap:24rpx;left:0;padding:24rpx;position:fixed;right:0;z-index:100}.liability-page .bottom-bar .btn{-webkit-align-items:center;border-radius:100rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;height:88rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:30rpx;font-weight:600;justify-content:center;margin:0}.liability-page .bottom-bar .btn::after{border:none}.liability-page .bottom-bar .btn:active{opacity:.8}.liability-page .bottom-bar .btn.btn-appeal{background-color:rgba(255,59,48,.1);color:#ff3b30}.liability-page .bottom-bar .btn.btn-accept{background-color:#ff3b30;color:#fff}.liability-page .bottom-bar .safe-bottom-space{bottom:0;height:env(safe-area-inset-bottom);left:0;position:absolute;right:0}