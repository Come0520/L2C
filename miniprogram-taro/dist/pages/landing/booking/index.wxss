.booking-page{background:#f2f2f7;min-height:100vh;padding:0 32rpx 48rpx}.booking-header{padding:48rpx 0 32rpx}.booking-header .header-title{color:#1d1d1f;display:block;font-size:36rpx;font-weight:700;margin-bottom:8rpx}.booking-header .header-desc{color:#6e6e73;display:block;font-size:28rpx}.form-card{background:#fff;border-radius:20rpx;-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.03);box-shadow:0 2rpx 12rpx rgba(0,0,0,.03);padding:0 24rpx}.form-card .form-item{padding:24rpx 0}.form-card .form-item:not(:last-child){border-bottom:1rpx solid rgba(60,60,67,.1)}.form-card .form-item .form-label{color:#6e6e73;display:block;font-size:24rpx;margin-bottom:16rpx}.form-card .form-item .form-label .required{color:#ff3b30;margin-left:4rpx}.form-card .form-item .form-input{color:#1d1d1f;font-size:32rpx;height:60rpx;min-height:60rpx}.form-card .form-item .picker-value{line-height:60rpx}.form-card .form-item .picker-value.placeholder{color:#aeaeb2}.booking-actions{margin-top:48rpx}.booking-actions .btn-primary{background:#0071e3;border:none;border-radius:20rpx;-webkit-box-shadow:0 4rpx 16rpx rgba(0,122,255,.25);box-shadow:0 4rpx 16rpx rgba(0,122,255,.25);color:#fff;font-size:32rpx;font-weight:600;height:104rpx;line-height:104rpx}.booking-actions .btn-primary[disabled]{background:#e0f0ff;-webkit-box-shadow:none;box-shadow:none;opacity:.6}.success-view{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;padding-top:200rpx;text-align:center}.success-view .success-icon{font-size:100rpx;margin-bottom:24rpx}.success-view .success-title{color:#1d1d1f;font-size:36rpx;font-weight:700;margin-bottom:16rpx}.success-view .success-desc{color:#6e6e73;font-size:28rpx;line-height:1.6;padding:0 48rpx}.success-view .mt-xl{margin-top:48rpx;width:60%}