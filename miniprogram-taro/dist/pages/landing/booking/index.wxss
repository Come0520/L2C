.booking-page{background:var(--color-bg);min-height:100vh;padding:0 var(--spacing-lg) var(--spacing-xl)}.booking-header{padding:var(--spacing-xl) 0 var(--spacing-lg)}.booking-header .header-title{color:var(--color-text);display:block;font-size:var(--font-size-xl);font-weight:700;margin-bottom:var(--spacing-xs)}.booking-header .header-desc{color:var(--color-text-secondary);display:block;font-size:var(--font-size-base)}.form-card{background:var(--color-bg-card);border-radius:var(--radius-md);-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.03);box-shadow:0 2rpx 12rpx rgba(0,0,0,.03);padding:0 var(--spacing-md)}.form-card .form-item{padding:var(--spacing-md) 0}.form-card .form-item:not(:last-child){border-bottom:1rpx solid var(--color-border)}.form-card .form-item .form-label{color:var(--color-text-secondary);display:block;font-size:var(--font-size-sm);margin-bottom:var(--spacing-sm)}.form-card .form-item .form-label .required{color:var(--color-danger);margin-left:4rpx}.form-card .form-item .form-input{color:var(--color-text);font-size:var(--font-size-lg);height:60rpx;min-height:60rpx}.form-card .form-item .picker-value{line-height:60rpx}.form-card .form-item .picker-value.placeholder{color:var(--color-text-placeholder)}.booking-actions{margin-top:var(--spacing-xl)}.booking-actions .btn-primary{background:var(--color-primary);border:none;border-radius:var(--radius-md);-webkit-box-shadow:0 4rpx 16rpx rgba(0,122,255,.25);box-shadow:0 4rpx 16rpx rgba(0,122,255,.25);color:#fff;font-size:var(--font-size-lg);font-weight:600;height:104rpx;line-height:104rpx}.booking-actions .btn-primary[disabled]{background:var(--color-primary-light);-webkit-box-shadow:none;box-shadow:none;opacity:.6}.success-view{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;padding-top:200rpx;text-align:center}.success-view .success-icon{font-size:100rpx;margin-bottom:var(--spacing-md)}.success-view .success-title{color:var(--color-text);font-size:var(--font-size-xl);font-weight:700;margin-bottom:var(--spacing-sm)}.success-view .success-desc{color:var(--color-text-secondary);font-size:var(--font-size-base);line-height:1.6;padding:0 var(--spacing-xl)}.success-view .mt-xl{margin-top:var(--spacing-xl);width:60%}