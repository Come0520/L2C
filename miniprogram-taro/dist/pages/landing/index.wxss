.landing-page{background:var(--color-bg-base);font-family:-apple-system,BlinkMacSystemFont,SF Pro Text,Helvetica Neue,Arial,sans-serif;min-height:100vh;padding:0 var(--spacing-lg) var(--spacing-xl)}.landing-page .landing-hero{padding:120rpx 0 80rpx;text-align:center}.landing-page .landing-hero .hero-logo{color:var(--color-text-title);display:block;font-size:var(--font-size-hero);font-weight:800;letter-spacing:-2rpx;line-height:1.1;margin-bottom:var(--spacing-md)}.landing-page .landing-hero .hero-title{color:var(--color-text-title);display:block;font-size:var(--font-size-xl);font-weight:600;letter-spacing:-.5rpx;margin-bottom:12rpx}.landing-page .landing-hero .hero-desc{color:var(--color-text-secondary);display:block;font-size:var(--font-size-lg);font-weight:400;line-height:1.4;margin:0 auto;max-width:80%}.landing-page .landing-actions{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;gap:var(--spacing-md);margin-bottom:80rpx}.landing-page .landing-actions button{border-radius:var(--radius-md);font-size:var(--font-size-lg);font-weight:600;height:100rpx;line-height:100rpx;margin:0;max-width:600rpx;padding:0;-webkit-transition:opacity .2s ease;transition:opacity .2s ease;width:100%}.landing-page .landing-actions button::after{border:none}.landing-page .landing-actions button:active{opacity:.7}.landing-page .landing-actions .btn-primary{background:var(--color-primary);color:#fff}.landing-page .landing-actions .btn-secondary{background:var(--color-bg-tint);color:var(--color-primary)}.landing-page .landing-actions .already-login{color:var(--color-text-secondary);display:block;font-size:var(--font-size-base);font-weight:500;margin-bottom:var(--spacing-sm);text-align:center}.landing-page .features{display:grid;gap:var(--spacing-md);grid-template-columns:1fr 1fr;padding-bottom:var(--spacing-xl)}.landing-page .features .feature-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;background:var(--color-bg-card);border-radius:var(--radius-lg);-webkit-box-shadow:var(--glass-shadow-soft);box-shadow:var(--glass-shadow-soft);-webkit-box-sizing:border-box;box-sizing:border-box;padding:var(--spacing-xl) var(--spacing-md);text-align:center}.landing-page .features .feature-item .feature-icon-wrap{-webkit-align-items:center;background-color:var(--color-bg-base);border-radius:var(--radius-sm);display:-webkit-flex;display:-ms-flexbox;display:flex;height:96rpx;width:96rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;margin-bottom:var(--spacing-md)}.landing-page .features .feature-item .feature-icon-wrap .feature-icon{font-size:56rpx;line-height:1}.landing-page .features .feature-item .feature-title{color:var(--color-text-title);font-size:var(--font-size-base);font-weight:600;letter-spacing:-.3rpx;margin-bottom:12rpx}.landing-page .features .feature-item .feature-desc{color:var(--color-text-secondary);font-size:var(--font-size-sm);line-height:1.5;white-space:normal;word-wrap:break-word}