.login-page{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh;padding:0 32rpx}.login-page .login-header{padding-bottom:48rpx;padding-top:160rpx;text-align:center}.login-page .login-header .login-logo{color:#1d1d1f;display:block;font-size:56rpx;font-weight:800;letter-spacing:-2rpx}.login-page .login-header .login-subtitle{color:#1d1d1f;color:#6e6e73;display:block;font-size:28rpx;line-height:1.5;margin-top:8rpx}.login-page .login-tabs{display:-webkit-flex;display:-ms-flexbox;display:flex;margin-bottom:32rpx}.login-page .login-tabs .login-tab{color:#1d1d1f;color:#aeaeb2;-webkit-flex:1;-ms-flex:1;flex:1;font-size:40rpx;font-size:32rpx;font-weight:600;letter-spacing:-.3rpx;line-height:1.3;padding:16rpx 0;position:relative;text-align:center;-webkit-transition:color .2s;transition:color .2s}.login-page .login-tabs .login-tab--active{color:#1d1d1f}.login-page .login-form-container{background-color:#fff;border-radius:20rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:0 24rpx 16rpx;overflow:hidden}.login-page .login-actions{margin-top:48rpx}.login-page .error-text{color:#6e6e73;color:#ff3b30;display:block;font-size:24rpx;letter-spacing:.3rpx;margin-bottom:24rpx;text-align:center}.login-page .login-footer{bottom:calc(constant(safe-area-inset-bottom) + 80rpx);bottom:calc(env(safe-area-inset-bottom) + 80rpx);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:center;left:0;position:absolute;right:0;-ms-flex-pack:center;gap:8rpx;justify-content:center}.login-page .login-footer .footer-text{color:#6e6e73;font-size:24rpx;letter-spacing:.3rpx}.login-page .login-footer .footer-link{color:#6e6e73;color:#0071e3;font-size:24rpx;font-weight:500;letter-spacing:.3rpx}