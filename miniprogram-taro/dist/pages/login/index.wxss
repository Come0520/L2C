.login-page{background:var(--color-bg);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100vh;padding:0 var(--spacing-lg)}.login-page .login-header{padding-bottom:var(--spacing-xl);padding-top:120rpx;text-align:center}.login-page .login-header .login-logo{color:var(--color-primary);display:block;font-size:72rpx;font-weight:900;letter-spacing:4rpx}.login-page .login-header .login-subtitle{color:var(--color-text-secondary);display:block;font-size:var(--font-size-sm);margin-top:var(--spacing-sm)}.login-page .login-tabs{border-bottom:1rpx solid var(--color-border);display:-webkit-flex;display:-ms-flexbox;display:flex;margin-bottom:var(--spacing-lg)}.login-page .login-tabs .login-tab{color:var(--color-text-secondary);-webkit-flex:1;-ms-flex:1;flex:1;font-size:var(--font-size-base);padding:var(--spacing-sm) 0;position:relative;text-align:center;-webkit-transition:color .2s;transition:color .2s}.login-page .login-tabs .login-tab--active{color:var(--color-primary)}.login-page .login-tabs .login-tab--active::after{background:var(--color-primary);border-radius:2rpx;bottom:-1rpx;content:"";height:2rpx;left:20%;position:absolute;right:20%}.login-page .login-form{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:var(--spacing-md)}.login-page .login-form .form-field{-webkit-align-items:center;background:var(--color-bg-card);border:1rpx solid var(--color-border);border-radius:var(--radius-md);display:-webkit-flex;display:-ms-flexbox;display:flex;height:96rpx;padding:0 var(--spacing-md);-ms-flex-align:center;align-items:center}.login-page .login-form .form-input{color:var(--color-text);-webkit-flex:1;-ms-flex:1;flex:1;font-size:var(--font-size-base);height:100%}.login-page .login-wechat{padding-top:var(--spacing-lg)}.login-page .error-text{color:var(--color-danger);font-size:var(--font-size-sm);text-align:center}.login-page .btn-primary{background:var(--color-primary);border:none;border-radius:var(--radius-md);color:#fff;font-size:var(--font-size-base);font-weight:700;height:96rpx;margin-top:var(--spacing-md);width:100%}.login-page .btn-wechat{background:#1aad19;border:none;border-radius:var(--radius-md);color:#fff;font-size:var(--font-size-base);font-weight:700;height:96rpx;width:100%}.login-page .login-footer{bottom:80rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:center;left:0;position:absolute;right:0;-ms-flex-pack:center;gap:8rpx;justify-content:center}.login-page .login-footer .footer-text{color:var(--color-text-secondary);font-size:var(--font-size-sm)}.login-page .login-footer .footer-link{color:var(--color-primary);font-size:var(--font-size-sm)}