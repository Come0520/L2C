.register-page{background:#f2f2f7;-webkit-box-sizing:border-box;box-sizing:border-box;color:#1d1d1f;font-size:28rpx;line-height:1.5;min-height:100vh;padding:0 24rpx calc(env(safe-area-inset-bottom) + 120rpx)}.register-page .page-header{padding:48rpx 8rpx 16rpx}.register-page .page-header .page-title{color:#1d1d1f;display:block;font-size:44rpx;font-size:44px;font-weight:700;letter-spacing:-.5rpx;line-height:1.2;margin-bottom:8rpx}.register-page .page-header .page-desc{color:#6e6e73;display:block;font-size:24rpx;font-size:28rpx;letter-spacing:.3rpx}.register-page .form-group-title{color:#6e6e73;display:block;font-size:24rpx;letter-spacing:.3rpx;margin:24rpx 8rpx 8rpx 28rpx;text-transform:uppercase}.register-page .form-group-title .optional{font-size:80%;font-weight:400}.register-page .form-group{background-color:#fff;border-radius:20rpx;-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);box-shadow:0 1rpx 4rpx rgba(0,0,0,.05);margin:0 24rpx 16rpx;overflow:hidden}.register-page .required{color:#ff3b30;margin-left:4rpx}.register-page .picker-input{-webkit-flex:1;-ms-flex:1;flex:1;height:88rpx;line-height:88rpx;text-align:right}.register-page .picker-value{text-align:right;width:100%}.register-page .textarea-row{-webkit-align-items:flex-start;min-height:200rpx;padding:24rpx;-ms-flex-align:start;align-items:flex-start}.register-page .textarea-row .textarea-input{height:160rpx;text-align:left;width:100%}.register-page .strength-bar-wrap{background:#fff;padding:8rpx 24rpx 16rpx 28rpx}.register-page .strength-bar-wrap .strength-bar-bg{background:#f2f2f7;border-radius:3rpx;height:6rpx;margin-bottom:8rpx;overflow:hidden}.register-page .strength-bar-wrap .strength-bar-fill{border-radius:3rpx;height:100%;-webkit-transition:width .3s ease,background-color .3s ease;transition:width .3s ease,background-color .3s ease}.register-page .strength-bar-wrap .strength-text{color:#6e6e73;font-size:24rpx;font-size:24px;font-weight:500;letter-spacing:.3rpx}.register-page .form-footer{margin-top:48rpx;padding:0 16rpx}.register-page .form-footer .error-box{margin-bottom:24rpx;text-align:center}.register-page .form-footer .error-box .error-text{color:#6e6e73;color:#ff3b30;font-size:24rpx;letter-spacing:.3rpx}