.register-page{background-color:var(--color-bg-base);-webkit-box-sizing:border-box;box-sizing:border-box;min-height:100vh;padding:var(--spacing-md) var(--spacing-sm);padding-bottom:env(safe-area-inset-bottom)}.register-page .page-header{padding:var(--spacing-lg) var(--spacing-md);padding-top:var(--spacing-sm)}.register-page .page-header .page-title{color:var(--color-text-title);display:block;font-size:64rpx;font-weight:700;letter-spacing:-.5rpx;margin-bottom:var(--spacing-xs)}.register-page .page-header .page-desc{color:var(--color-text-secondary);display:block;font-size:var(--font-size-sm);line-height:1.4}.register-page .form-group-title{color:var(--color-text-secondary);font-size:var(--font-size-xs);letter-spacing:.5rpx;padding:var(--spacing-sm) var(--spacing-md) 8rpx;text-transform:uppercase}.register-page .form-group{background-color:var(--color-bg-card);border-radius:var(--radius-sm);-webkit-box-shadow:0 1rpx 4rpx rgba(0,0,0,.02);box-shadow:0 1rpx 4rpx rgba(0,0,0,.02);margin:0 var(--spacing-md) var(--spacing-lg)}.register-page .form-group .form-row{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;min-height:88rpx;padding:0 var(--spacing-sm) 0 var(--spacing-md);position:relative}.register-page .form-group .form-divider{background-color:var(--color-border-separator);height:1rpx;margin-left:var(--spacing-md)}.register-page .form-group .form-label{color:var(--color-text-body);-webkit-flex-shrink:0;font-size:var(--font-size-lg);font-weight:500;width:160rpx;-ms-flex-negative:0;flex-shrink:0}.register-page .form-group .form-input{color:var(--color-text-body);-webkit-flex:1;-ms-flex:1;flex:1;font-size:var(--font-size-lg);height:88rpx;padding-right:var(--spacing-xs);text-align:right}.register-page .form-group .ph-color{color:var(--color-text-placeholder)}.register-page .role-group .role-row{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-