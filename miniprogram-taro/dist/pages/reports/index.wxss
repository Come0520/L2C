.reports-page{background:#f2f2f7;min-height:100vh;padding-bottom:40rpx}.reports-page .period-tabs{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:16rpx;padding:24rpx}.reports-page .period-tabs .period-tab{background:#fff;border-radius:100rpx;color:#6e6e73;font-size:24rpx;padding:8rpx 32rpx;-webkit-transition:all .2s;transition:all .2s}.reports-page .period-tabs .period-tab--active{background:#0071e3;color:#fff;font-weight:600}.reports-page .reports-scroll{height:calc(100vh - 120rpx);padding:0 24rpx}.reports-page .kpi-grid{display:grid;gap:16rpx;grid-template-columns:1fr 1fr;margin-bottom:24rpx}.reports-page .kpi-grid .kpi-card{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;padding:24rpx}.reports-page .kpi-grid .kpi-card .kpi-value{color:#0071e3;font-size:40rpx;font-weight:700}.reports-page .kpi-grid .kpi-card .kpi-value .kpi-unit{font-size:24rpx;font-weight:400}.reports-page .kpi-grid .kpi-card .kpi-label{color:#6e6e73;font-size:22rpx;margin-top:4rpx}.reports-page .kpi-grid .kpi-card .kpi-trend{font-size:22rpx;margin-top:4rpx}.reports-page .kpi-grid .kpi-card .kpi-trend--up{color:#34c759}.reports-page .kpi-grid .kpi-card .kpi-trend--down{color:#ff3b30}.reports-page .section-title{display:block;font-size:32rpx;font-weight:600;margin-bottom:16rpx}.reports-page .rank-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:16rpx;margin-bottom:8rpx}.reports-page .rank-item .rank-no{color:#0071e3;font-size:36rpx;font-weight:900;text-align:center;width:40rpx}.reports-page .rank-item .rank-name{font-size:28rpx}.reports-page .rank-item .rank-amount{color:#0071e3;display:block;font-size:28rpx;font-weight:700;text-align:right}.reports-page .rank-item .rank-count{color:#6e6e73;display:block;font-size:22rpx;text-align:right}.reports-page .web-guide{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;margin-top:24rpx;-ms-flex-align:center;align-items:center;padding:32rpx;text-align:center}.reports-page .web-guide .web-guide-title{font-size:28rpx;font-weight:600}.reports-page .web-guide .web-guide-desc{color:#6e6e73;font-size:24rpx;margin-top:4rpx}