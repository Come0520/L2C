.reports-page{background:var(--color-bg);min-height:100vh;padding-bottom:40rpx}.reports-page .period-tabs{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:var(--spacing-sm);padding:var(--spacing-md)}.reports-page .period-tabs .period-tab{background:var(--color-bg-card);border-radius:var(--radius-full);color:var(--color-text-secondary);font-size:var(--font-size-sm);padding:8rpx 32rpx;-webkit-transition:all .2s;transition:all .2s}.reports-page .period-tabs .period-tab--active{background:var(--color-primary);color:#fff;font-weight:600}.reports-page .reports-scroll{height:calc(100vh - 120rpx);padding:0 var(--spacing-md)}.reports-page .kpi-grid{display:grid;gap:var(--spacing-sm);grid-template-columns:1fr 1fr;margin-bottom:var(--spacing-md)}.reports-page .kpi-grid .kpi-card{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;padding:var(--spacing-md)}.reports-page .kpi-grid .kpi-card .kpi-value{color:var(--color-primary);font-size:var(--font-size-xxl);font-weight:700}.reports-page .kpi-grid .kpi-card .kpi-value .kpi-unit{font-size:var(--font-size-sm);font-weight:400}.reports-page .kpi-grid .kpi-card .kpi-label{color:var(--color-text-secondary);font-size:var(--font-size-xs);margin-top:4rpx}.reports-page .kpi-grid .kpi-card .kpi-trend{font-size:var(--font-size-xs);margin-top:4rpx}.reports-page .kpi-grid .kpi-card .kpi-trend--up{color:var(--color-success)}.reports-page .kpi-grid .kpi-card .kpi-trend--down{color:var(--color-danger)}.reports-page .section-title{display:block;font-size:var(--font-size-lg);font-weight:600;margin-bottom:var(--spacing-sm)}.reports-page .rank-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:var(--spacing-sm);margin-bottom:var(--spacing-xs)}.reports-page .rank-item .rank-no{color:var(--color-primary);font-size:var(--font-size-xl);font-weight:900;text-align:center;width:40rpx}.reports-page .rank-item .rank-name{font-size:var(--font-size-base)}.reports-page .rank-item .rank-amount{color:var(--color-primary);display:block;font-size:var(--font-size-base);font-weight:700;text-align:right}.reports-page .rank-item .rank-count{color:var(--color-text-secondary);display:block;font-size:var(--font-size-xs);text-align:right}.reports-page .web-guide{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;margin-top:var(--spacing-md);-ms-flex-align:center;align-items:center;padding:var(--spacing-lg);text-align:center}.reports-page .web-guide .web-guide-title{font-size:var(--font-size-base);font-weight:600}.reports-page .web-guide .web-guide-desc{color:var(--color-text-secondary);font-size:var(--font-size-sm);margin-top:4rpx}