.showroom-page{background:var(--color-bg);min-height:100vh;padding-bottom:120rpx}.showroom-page .showroom-header{padding:var(--spacing-lg) var(--spacing-md) var(--spacing-sm)}.showroom-page .showroom-header .header-title{display:block;font-size:var(--font-size-xxl);font-weight:700}.showroom-page .showroom-header .header-subtitle{color:var(--color-text-secondary);display:block;font-size:var(--font-size-xs);margin-top:4rpx}.showroom-page .category-tabs{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:var(--spacing-sm);margin-bottom:var(--spacing-md);padding:0 var(--spacing-md)}.showroom-page .category-tabs .category-tab{background:var(--color-bg-card);border-radius:var(--radius-full);color:var(--color-text-secondary);font-size:var(--font-size-sm);padding:8rpx 24rpx;-webkit-transition:all .2s;transition:all .2s}.showroom-page .category-tabs .category-tab--active{background:var(--color-primary);color:#fff;font-weight:600}.showroom-page .content-list{height:calc(100vh - 200rpx - 120rpx);padding:0 var(--spacing-md)}.showroom-page .empty-state{-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:120rpx 0}.showroom-page .empty-state .empty-icon{font-size:80rpx;margin-bottom:var(--spacing-md)}.showroom-page .empty-state .empty-text{color:var(--color-text-secondary)}.showroom-page .showroom-card{margin-bottom:var(--spacing-md);overflow:hidden;padding:0}.showroom-page .showroom-card .card-cover{height:320rpx;width:100%}.showroom-page .showroom-card .card-body{padding:var(--spacing-md)}.showroom-page .showroom-card .card-meta{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:var(--spacing-sm);margin-bottom:var(--spacing-xs)}.showroom-page .showroom-card .type-badge{border-radius:var(--radius-sm);font-size:var(--font-size-xs);padding:2rpx 12rpx}.showroom-page .showroom-card .type-badge--article{background:rgba(64,158,255,.15);color:#409eff}.showroom-page .showroom-card .type-badge--case{background:rgba(103,194,58,.15);color:var(--color-success)}.showroom-page .showroom-card .type-badge--product{background:rgba(230,180,80,.15);color:var(--color-primary)}.showroom-page .showroom-card .view-count{color:var(--color-text-placeholder);font-size:var(--font-size-xs)}.showroom-page .showroom-card .card-title{display:block;font-size:var(--font-size-lg);font-weight:600;margin-bottom:4rpx}.showroom-page .showroom-card .card-desc{color:var(--color-text-secondary);display:block;font-size:var(--font-size-sm)}.showroom-page .showroom-card .btn-share{-webkit-align-items:center;display:-webkit-inline-flex;display:-ms-inline-flexbox;display:inline-flex;margin-top:var(--spacing-sm);-ms-flex-align:center;align-items:center;background:rgba(230,180,80,.1);border:1rpx solid rgba(230,180,80,.3);border-radius:var(--radius-md);color:var(--color-primary);font-size:var(--font-size-sm);padding:8rpx 24rpx}.showroom-page .loading{color:var(--color-text-secondary);padding:var(--spacing-xl)}