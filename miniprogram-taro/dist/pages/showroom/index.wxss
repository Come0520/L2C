.showroom-page{background:#f2f2f7;min-height:100vh;padding-bottom:120rpx}.showroom-page .showroom-header{padding:32rpx 24rpx 16rpx}.showroom-page .showroom-header .header-title{display:block;font-size:40rpx;font-weight:700}.showroom-page .showroom-header .header-subtitle{color:#6e6e73;display:block;font-size:22rpx;margin-top:4rpx}.showroom-page .category-tabs{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:16rpx;margin-bottom:24rpx;padding:0 24rpx}.showroom-page .category-tabs .category-tab{background:#fff;border-radius:100rpx;color:#6e6e73;font-size:24rpx;padding:8rpx 24rpx;-webkit-transition:all .2s;transition:all .2s}.showroom-page .category-tabs .category-tab--active{background:#0071e3;color:#fff;font-weight:600}.showroom-page .content-list{height:calc(100vh - 200rpx - 120rpx);padding:0 24rpx}.showroom-page .empty-state{-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:120rpx 0}.showroom-page .empty-state .empty-icon{font-size:80rpx;margin-bottom:24rpx}.showroom-page .empty-state .empty-text{color:#6e6e73}.showroom-page .card-grid{display:grid;gap:24rpx;grid-template-columns:repeat(2,1fr);padding-bottom:24rpx}.showroom-page .showroom-card{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;margin-bottom:0;overflow:hidden;padding:0}.showroom-page .showroom-card .card-cover{background-color:#f5f5f5;height:300rpx;width:100%}.showroom-page .showroom-card .card-body{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:16rpx}.showroom-page .showroom-card .card-meta{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:4rpx;justify-content:space-between;margin-bottom:8rpx}.showroom-page .showroom-card .type-badge{border-radius:16rpx;font-size:20rpx;padding:2rpx 8rpx}.showroom-page .showroom-card .type-badge--article{background:rgba(64,158,255,.15);color:#409eff}.showroom-page .showroom-card .type-badge--case{background:rgba(103,194,58,.15);color:#34c759}.showroom-page .showroom-card .type-badge--product{background:rgba(230,180,80,.15);color:#0071e3}.showroom-page .showroom-card .view-count{color:#aeaeb2;font-size:20rpx}.showroom-page .showroom-card .card-title{display:block;display:-webkit-box;font-size:24rpx;font-weight:600;-webkit-line-clamp:2;line-clamp:2;line-height:1.4;margin-bottom:4rpx;-webkit-box-orient:vertical;white-space:normal}.showroom-page .showroom-card .card-desc{color:#6e6e73;display:block;font-size:22rpx;white-space:nowrap}.showroom-page .showroom-card .btn-share{-webkit-align-items:center;display:-webkit-inline-flex;display:-ms-inline-flexbox;display:inline-flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;background:rgba(230,180,80,.1);border:1rpx solid rgba(230,180,80,.3);border-radius:16rpx;color:#0071e3;font-size:22rpx;justify-content:center;margin-top:16rpx;padding:10rpx 0;width:100%}.showroom-page .loading{color:#6e6e73;padding:48rpx}