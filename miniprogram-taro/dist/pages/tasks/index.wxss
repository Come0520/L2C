.tasks-page{background:#f2f2f7;min-height:100vh;padding-bottom:120rpx}.tasks-page .tasks-tabs{background:#f2f2f7;border-bottom:1rpx solid rgba(60,60,67,.1);display:-webkit-flex;display:-ms-flexbox;display:flex;position:-webkit-sticky;position:sticky;top:0;z-index:10}.tasks-page .tasks-tabs .tasks-tab{color:#6e6e73;-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx;padding:16rpx 0;position:relative;text-align:center;-webkit-transition:color .2s;transition:color .2s}.tasks-page .tasks-tabs .tasks-tab--active{color:#0071e3;font-weight:600}.tasks-page .tasks-tabs .tasks-tab--active::after{background:#0071e3;border-radius:3rpx;bottom:-1rpx;content:"";height:3rpx;left:25%;position:absolute;right:25%}.tasks-page .tasks-list{height:calc(100vh - 90rpx - 120rpx);padding:16rpx 24rpx}.tasks-page .empty-state{-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:120rpx 0}.tasks-page .empty-state .empty-icon{font-size:80rpx;margin-bottom:24rpx}.tasks-page .empty-state .empty-text{color:#6e6e73;font-size:28rpx}.tasks-page .task-card__header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center;margin-bottom:16rpx}.tasks-page .task-card .task-type-badge{border-radius:100rpx;font-size:22rpx;font-weight:600;padding:4rpx 16rpx}.tasks-page .task-card .task-type-badge--measure{background:rgba(103,194,58,.15);color:#34c759}.tasks-page .task-card .task-type-badge--install{background:rgba(230,162,60,.15);color:#ff9500}.tasks-page .task-card .task-date{color:#6e6e73;font-size:22rpx}.tasks-page .task-card .task-customer{display:block;font-size:32rpx;font-weight:600;margin-bottom:4rpx}.tasks-page .task-card .task-address{color:#6e6e73;display:block;font-size:24rpx;margin-bottom:8rpx}.tasks-page .task-card .task-rooms{color:#aeaeb2;font-size:22rpx}.tasks-page .task-card .task-actions{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:flex-end;margin-top:16rpx;-ms-flex-pack:end;justify-content:flex-end}.tasks-page .task-card .task-actions .btn-accept{background:#0071e3;border-radius:20rpx;color:#fff;font-size:24rpx;font-weight:700;padding:8rpx 32rpx}.tasks-page .loading{color:#6e6e73;padding:48rpx}