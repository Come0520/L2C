.profile-page{background:var(--color-bg);min-height:100vh;padding-bottom:120rpx}.profile-page .profile-card{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;background:var(--color-bg);gap:var(--spacing-md);padding:var(--spacing-xl) var(--spacing-md) var(--spacing-lg)}.profile-page .profile-card .avatar-wrap{-webkit-flex-shrink:0;-ms-flex-negative:0;flex-shrink:0}.profile-page .profile-card .avatar{border:3rpx solid var(--color-primary);border-radius:50%;height:120rpx;width:120rpx}.profile-page .profile-card .avatar--default{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;background:var(--color-bg-elevated);color:var(--color-primary);font-size:var(--font-size-xxl);font-weight:700;justify-content:center}.profile-page .profile-card .profile-info{-webkit-flex:1;-ms-flex:1;flex:1}.profile-page .profile-card .profile-info .profile-name{display:block;font-size:var(--font-size-xl);font-weight:700}.profile-page .profile-card .profile-info .profile-role{color:var(--color-primary);display:block;font-size:var(--font-size-sm);margin-top:4rpx}.profile-page .profile-card .profile-info .profile-tenant{color:var(--color-text-secondary);display:block;font-size:var(--font-size-xs);margin-top:4rpx}.profile-page .menu-section{padding:var(--spacing-md)}.profile-page .menu-section .menu-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-bottom:1rpx solid var(--color-border);gap:var(--spacing-sm);padding:var(--spacing-md) var(--spacing-sm)}.profile-page .menu-section .menu-item:active{background:var(--color-bg-card)}.profile-page .menu-section .menu-item .menu-icon{font-size:var(--font-size-lg);text-align:center;width:40rpx}.profile-page .menu-section .menu-item .menu-label{-webkit-flex:1;-ms-flex:1;flex:1;font-size:var(--font-size-base)}.profile-page .menu-section .menu-item .menu-arrow{color:var(--color-text-secondary);font-size:var(--font-size-xl)}.profile-page .logout-section{padding:var(--spacing-xl) var(--spacing-md)}.profile-page .logout-section .logout-btn{border:1rpx solid var(--color-danger);border-radius:var(--radius-md);color:var(--color-danger);font-size:var(--font-size-base);padding:var(--spacing-sm) 0;text-align:center}.profile-page .logout-section .logout-btn:active{background:hsla(0,87%,69%,.1)}