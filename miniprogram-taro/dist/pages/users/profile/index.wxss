.profile-page{background:#f2f2f7;min-height:100vh;padding-bottom:120rpx}.profile-page .profile-card{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;background:#f2f2f7;gap:24rpx;padding:48rpx 24rpx 32rpx}.profile-page .profile-card .avatar-wrap{-webkit-flex-shrink:0;-ms-flex-negative:0;flex-shrink:0}.profile-page .profile-card .avatar{border:3rpx solid #0071e3;border-radius:50%;height:120rpx;width:120rpx}.profile-page .profile-card .avatar--default{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;background:#fff;color:#0071e3;font-size:40rpx;font-weight:700;justify-content:center}.profile-page .profile-card .profile-info{-webkit-flex:1;-ms-flex:1;flex:1}.profile-page .profile-card .profile-info .profile-name{display:block;font-size:36rpx;font-weight:700}.profile-page .profile-card .profile-info .profile-role{color:#0071e3;display:block;font-size:24rpx;margin-top:4rpx}.profile-page .profile-card .profile-info .profile-tenant{color:#6e6e73;display:block;font-size:22rpx;margin-top:4rpx}.profile-page .menu-section{padding:24rpx}.profile-page .menu-section .menu-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-bottom:1rpx solid rgba(60,60,67,.1);gap:16rpx;padding:24rpx 16rpx}.profile-page .menu-section .menu-item:active{background:#fff}.profile-page .menu-section .menu-item .menu-icon{font-size:32rpx;text-align:center;width:40rpx}.profile-page .menu-section .menu-item .menu-label{-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx}.profile-page .menu-section .menu-item .menu-arrow{color:#6e6e73;font-size:36rpx}.profile-page .logout-section{padding:48rpx 24rpx}.profile-page .logout-section .logout-btn{border:1rpx solid #ff3b30;border-radius:20rpx;color:#ff3b30;font-size:28rpx;padding:16rpx 0;text-align:center}.profile-page .logout-section .logout-btn:active{background:hsla(0,87%,69%,.1)}