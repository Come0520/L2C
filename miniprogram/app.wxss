/**
 * L2C 小程序全局样式 - Apple-style Glassmorphism (磨砂玻璃风)
 */

/* ========== 设计令牌 (Design Tokens) ========== */
page {
  /* 品牌色 - 蓝紫系 */
  --brand-primary: #2563EB;
  --brand-indigo: #4F46E5;
  --brand-light: #EFF6FF;
  --brand-hover: #1D4ED8;
  --brand-100: #DBEAFE;

  /* 玻璃态变量 (Glassmorphism Variables) */
  --glass-bg: rgba(255, 255, 255, 0.65);
  --glass-border: rgba(255, 255, 255, 0.5);
  --glass-border-light: rgba(255, 255, 255, 0.3);
  --glass-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.05);
  --glass-shadow-hover: 0 16rpx 48rpx rgba(31, 38, 135, 0.1);

  /* 文字 */
  --text-heading: #111827;
  --text-body: #4B5563;
  --text-muted: #6B7280; /* 加深了一点以保证在半透明背景上的对比度 */
  --text-placeholder: #9CA3AF;

  /* 状态色 */
  --status-success: #16A34A;
  --status-warning: #EAB308;
  --status-danger: #DC2626;
  --status-info: #2563EB;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 圆角 (squircle/apple-style) */
  --radius-sm: 12rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-full: 999rpx;

  /* 全局字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-body);
  /* 使用一个极浅的底色，配合后续动态/渐变背景 */
  background-color: #F8FAFC; 
  line-height: 1.6;
}

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 var(--spacing-lg);
  /* 让页面的容器透明，透出 page 的底色或特殊背景层 */
  background: transparent;
  position: relative;
  z-index: 1;
}

/* ========== 卡片 (Glass Card) ========== */
.card {
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--glass-shadow);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-hover, .card:active {
  transform: translateY(-2rpx) scale(0.995);
  box-shadow: var(--glass-shadow-hover);
  background: rgba(255, 255, 255, 0.75);
}

/* ========== 按钮 ========== */
.btn-primary {
  background: linear-gradient(135deg, var(--brand-primary), var(--brand-indigo));
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-full);
  font-weight: 600;
  font-size: 30rpx;
  padding: 24rpx 0;
  text-align: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
}

.btn-primary:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.15);
  opacity: 0.9;
}

.btn-secondary {
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  color: var(--text-heading);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-full);
  font-weight: 500;
  font-size: 28rpx;
  padding: 24rpx 0;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: var(--glass-shadow);
}

.btn-secondary:active, .btn-secondary-hover {
  background: rgba(255, 255, 255, 0.8);
  transform: translateY(2rpx) scale(0.98);
}

/* ========== 状态徽章 ========== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  /* 徽章也采用微透明或柔和光泽 */
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.badge-success {
  background: rgba(22, 163, 74, 0.1);
  color: var(--status-success);
  border: 1rpx solid rgba(22, 163, 74, 0.2);
}

.badge-warning {
  background: rgba(234, 179, 8, 0.1);
  color: #B45309; /* 加深的 yellow-700 保证对比度 */
  border: 1rpx solid rgba(234, 179, 8, 0.2);
}

.badge-danger {
  background: rgba(220, 38, 38, 0.1);
  color: var(--status-danger);
  border: 1rpx solid rgba(220, 38, 38, 0.2);
}

.badge-info {
  background: rgba(37, 99, 235, 0.1);
  color: var(--brand-primary);
  border: 1rpx solid rgba(37, 99, 235, 0.2);
}

/* ========== 分隔线 ========== */
.divider {
  height: 1rpx;
  background: var(--glass-border-light);
  margin: var(--spacing-md) 0;
}

/* ========== 搜索栏 ========== */
.search-bar {
  padding: var(--spacing-sm) 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-full);
  padding: 16rpx 32rpx;
  gap: 16rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.02);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-heading);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-muted);
  font-size: 28rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.6;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}

.load-more, .loading-more, .no-more {
  text-align: center;
  padding: 32rpx 0;
  color: var(--text-muted);
  font-size: 24rpx;
}

/* ========== FAB 浮动按钮 ========== */
.fab-add {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--brand-primary), var(--brand-indigo));
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.4);
  z-index: 100;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.fab-add:active, .fab-active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
}

/* ========== 页面区块标题 ========== */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-heading);
  margin-bottom: var(--spacing-md);
  letter-spacing: 0.5rpx;
}

/* ========== 动画 ========== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx) scale(0.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.animate-fade-in {
  animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-slide-up {
  opacity: 0;
  animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* ========== 通用工具 ========== */
.text-primary { color: var(--brand-primary); }
.text-heading { color: var(--text-heading); }
.text-muted { color: var(--text-muted); }
.bg-brand-light { background: var(--brand-light); }

.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }

/* ========== 安全区域 ========== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top {
  padding-top: env(safe-area-inset-top);
}

