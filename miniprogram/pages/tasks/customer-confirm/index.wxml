<!--pages/tasks/customer-confirm/index.wxml-->
<view class="container" wx:if="{{!loading}}">

  <!-- 已确认状态 -->
  <view wx:if="{{task.customerSignatureUrl}}" class="confirmed-banner">
    <text class="confirmed-icon">✅</text>
    <text class="confirmed-text">您已完成签字确认</text>
  </view>

  <!-- 顶部任务信息 -->
  <view class="card info-card">
    <view class="info-title">📋 完工确认单</view>
    <view class="info-row">
      <text class="info-label">项目地址</text>
      <text class="info-val">{{task.customerAddress || '暂无'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">完工时间</text>
      <text class="info-val">{{task.completedAt || '暂无'}}</text>
    </view>
    <view class="info-row" wx:if="{{task.remark}}">
      <text class="info-label">师傅备注</text>
      <text class="info-val">{{task.remark}}</text>
    </view>
  </view>

  <!-- 完工照片 -->
  <view class="card" wx:if="{{task.photos && task.photos.length}}">
    <view class="section-title">📷 现场完工照片</view>
    <view class="photo-grid">
      <image
        wx:for="{{task.photos}}"
        wx:key="index"
        src="{{item}}"
        class="photo-item"
        mode="aspectFill"
        bindtap="previewPhoto"
        data-src="{{item}}"
      />
    </view>
  </view>

  <!-- 已签字展示 -->
  <view class="card signed-card" wx:if="{{task.customerSignatureUrl}}">
    <view class="section-title">✍️ 您的签字</view>
    <image class="signed-img" src="{{task.customerSignatureUrl}}" mode="aspectFit" />
  </view>

  <!-- 签字CTA（未签字时显示） -->
  <view class="cta-section" wx:elif="{{!task.customerSignatureUrl}}">
    <view class="cta-hint">请确认上方照片无误后，点击按钮完成签字确认</view>
    <button class="btn-sign" bindtap="openSignModal">✍️ 点击签字确认完工</button>
  </view>

</view>

<!-- 加载中 -->
<view wx:if="{{loading}}" class="loading-state">
  <view class="spinner"></view>
  <text>加载中...</text>
</view>

<!-- ===== 签字弹窗 ===== -->
<view class="modal-mask" wx:if="{{showSignModal}}" catchtap="closeSignModal">
  <view class="modal-card" catchtap="">
    <view class="modal-header">
      <view class="modal-title">客户签字确认</view>
      <view class="modal-close" bindtap="closeSignModal">✕</view>
    </view>
    <view class="modal-desc">请在下方区域手写签名，表示您已确认验收完工结果</view>

    <view class="canvas-wrap">
      <signature id="customer-signature" width="{{signatureWidth}}" height="180" lineColor="#1a1a1a" lineWidth="4" />
    </view>

    <view class="modal-actions">
      <button class="btn-resign" bindtap="handleClear">重新签名</button>
      <button class="btn-confirm-sign" bindtap="handleConfirm" loading="{{submitting}}">确认提交</button>
    </view>
  </view>
</view>
