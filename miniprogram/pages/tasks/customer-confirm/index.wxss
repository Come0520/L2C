/* pages/tasks/customer-confirm/index.wxss */

.container {
  padding: 24rpx;
  background: var(--bg-page);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 已确认横幅 */
.confirmed-banner {
  background: rgba(16, 185, 129, 0.12);
  border-radius: var(--radius-md);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.confirmed-icon {
  font-size: 40rpx;
}

.confirmed-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--status-success);
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.info-card {
  border-top: 6rpx solid var(--brand-primary);
}

.info-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-heading);
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-light);
  gap: 24rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--text-muted);
}

.info-val {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-heading);
  margin-bottom: 24rpx;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  background: var(--bg-section);
}

/* 已签字图 */
.signed-card {
  border-left: 6rpx solid var(--status-success);
}

.signed-img {
  width: 100%;
  height: 220rpx;
  border-radius: var(--radius-md);
  background: var(--bg-section);
}

/* 签字CTA */
.cta-section {
  padding: 40rpx 0;
  text-align: center;
}

.cta-hint {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.btn-sign {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 24rpx rgba(26, 115, 232, 0.35);
  letter-spacing: 2rpx;
}

/* 加载 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  color: var(--text-muted);
}

/* 签字弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-heading);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-section);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-muted);
}

.modal-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 28rpx;
  line-height: 1.6;
}

.canvas-wrap {
  background: #fff;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 2rpx dashed #d0d0d0;
  margin-bottom: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-resign {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--bg-section);
  color: var(--text-heading);
  font-size: 28rpx;
  border-radius: var(--radius-md);
}

.btn-confirm-sign {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(26, 115, 232, 0.3);
}
