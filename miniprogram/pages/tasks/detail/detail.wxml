<!-- pages/tasks/detail/detail.wxml -->
<view class="container" wx:if="{{task}}">
  <!-- Header Card -->
  <view class="card header-card">
    <view class="title-row">
      <text class="task-no">{{task.measureNo || task.taskNo}}</text>
      <text class="status-tag status-{{task.status}}">{{statusText}}</text>
    </view>
    <view class="time-row">
      <icon class="icon" type="waiting" size="14" color="var(--text-muted)" />
      <text>预约时间：{{scheduledTime}}</text>
    </view>
  </view>

  <!-- Customer Info Card -->
  <view class="card">
    <view class="section-title">客户信息</view>
    <view class="address-box">
      <view class="address-text">{{task.customerAddress || task.address}}</view>
      <view class="contact-row">
        <view class="contact-info">
          <text class="name">{{task.customerName}}</text>
          <text class="phone" bindtap="makePhoneCall" data-phone="{{task.customerPhone}}">{{task.customerPhone}}</text>
        </view>
        <view class="action-bar">
           <view class="action-btn" bindtap="openLocation" hover-class="action-btn-hover">
             <text class="action-icon">📍</text>
             <text>导航</text>
           </view>
           <view class="action-btn" bindtap="makePhoneCall" data-phone="{{task.customerPhone}}" hover-class="action-btn-hover">
             <text class="action-icon">📞</text>
             <text>拨打</text>
           </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Remark Card -->
  <view class="card" wx:if="{{task.remark}}">
    <view class="section-title">备注</view>
    <view class="remark-content">{{task.remark}}</view>
  </view>

  <!-- 已完工展示 -->
  <view class="card completed-card" wx:if="{{task.status === 'COMPLETED' && task.customerSignatureUrl}}">
    <view class="section-title">✅ 完工已确认</view>
    <view class="completed-photos" wx:if="{{task.photos && task.photos.length}}">
      <view class="section-label">现场照片</view>
      <scroll-view scroll-x class="photo-scroll">
        <image wx:for="{{task.photos}}" wx:key="index" src="{{item}}" class="photo-thumb" mode="aspectFill" bindtap="previewPhoto" data-src="{{item}}" />
      </scroll-view>
    </view>
    <view class="signed-area">
      <view class="section-label">客户签字</view>
      <image class="signed-img" src="{{task.customerSignatureUrl}}" mode="aspectFit" />
    </view>
  </view>
  
  <view class="footer-spacer"></view>

  <!-- Bottom Action Bar -->
  <view class="bottom-bar">
     <button 
        wx:if="{{task.status === 'PENDING' || task.status === 'PENDING_DISPATCH'}}" 
        class="btn-primary btn-flex"
        bindtap="updateStatus" 
        data-status="IN_PROGRESS"
        data-action="accept"
     >接单出发</button>

     <button 
        wx:if="{{task.status === 'IN_PROGRESS' || task.status === 'ASSIGNED'}}" 
        class="btn-secondary btn-flex"
        bindtap="checkIn"
     >签到</button>

     <button 
        wx:if="{{task.status === 'IN_PROGRESS'}}" 
        class="btn-primary btn-flex"
        bindtap="openCompleteModal"
     >完工确认</button>
  </view>
</view>

<!-- Loading State -->
<view wx:if="{{loading}}" class="loading-state">
  <view class="spinner"></view>
  <text>加载中...</text>
</view>

<!-- Error State -->
<view wx:if="{{error}}" class="empty-state">
    <text class="empty-text">{{error}}</text>
    <button class="btn-primary btn-retry" bindtap="onLoad">重试</button>
</view>

<!-- ============================= -->
<!-- 完工确认弹窗                    -->
<!-- ============================= -->
<view class="modal-mask" wx:if="{{showCompleteModal}}" catchtap="closeCompleteModal">
  <view class="modal-card" catchtap="">
    <!-- 弹窗顶部 -->
    <view class="modal-header">
      <view class="modal-title">完工确认</view>
      <view class="modal-close" bindtap="closeCompleteModal">✕</view>
    </view>

    <!-- 现场照片上传 -->
    <view class="modal-section">
      <view class="modal-label">📷 现场照片（选填）</view>
      <view class="photo-grid">
        <image 
          wx:for="{{uploadedPhotos}}" 
          wx:key="index" 
          src="{{item}}" 
          class="photo-thumb-sm"
          mode="aspectFill"
        />
        <view class="add-photo-btn" bindtap="pickPhoto" wx:if="{{uploadedPhotos.length < 6}}">
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="modal-section">
      <view class="modal-label">📝 完工备注（选填）</view>
      <textarea 
        class="remark-textarea" 
        placeholder="请输入完工说明..." 
        bindinput="onRemarkInput"
        value="{{completeRemark}}"
        maxlength="200"
      />
    </view>

    <!-- 客户签字 -->
    <view class="modal-section">
      <view class="modal-label sign-label">
        <text>✍️ 客户签字</text>
        <text class="sign-hint-sm">（请将手机递给客户签名）</text>
      </view>
      <view class="sign-canvas-wrap">
        <signature id="task-signature" width="{{signatureWidth}}" height="160" lineColor="#1a1a1a" lineWidth="4" />
      </view>
      <view class="btn-resign-sm" bindtap="handleTaskSignClear">重新签名</view>
    </view>

    <!-- 操作按钮 -->
    <view class="modal-actions">
      <button class="btn-cancel" bindtap="closeCompleteModal">取消</button>
      <button class="btn-submit-complete" bindtap="submitComplete" loading="{{submitting}}">提交完工</button>
    </view>
  </view>
</view>
