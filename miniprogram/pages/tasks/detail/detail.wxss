/* pages/tasks/detail/detail.wxss */
.container {
  padding: 24rpx;
  background-color: var(--bg-page);
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.header-card {
  position: relative;
  overflow: hidden;
}

.header-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, var(--brand-primary), #8b5cf6);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-no {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-heading);
  font-family: 'DIN Alternate', sans-serif;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-section);
  color: var(--text-muted);
}

.status-PENDING_VISIT, .status-PENDING {
  background: var(--brand-light);
  color: var(--brand-primary);
}

.status-COMPLETED {
  background: rgba(16, 185, 129, 0.1);
  color: var(--status-success);
}

.status-REJECTED, .status-CANCELLED {
  background: rgba(239, 68, 68, 0.1);
  color: var(--status-danger);
}

.time-row {
  display: flex;
  align-items: center;
  color: var(--text-muted);
  font-size: 28rpx;
  gap: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-heading);
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: var(--brand-primary);
  border-radius: 4rpx;
}

.address-box {
  background: var(--bg-section);
  padding: 24rpx;
  border-radius: var(--radius-md);
}

.address-text {
  font-size: 30rpx;
  color: var(--text-heading);
  margin-bottom: 16rpx;
  line-height: 1.5;
  font-weight: 500;
}

.contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx dashed var(--border-light);
  padding-top: 16rpx;
}

.contact-info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 28rpx;
  color: var(--text-heading);
  margin-bottom: 8rpx;
}

.phone {
  font-size: 28rpx;
  color: var(--brand-primary);
  font-weight: bold;
}

.action-bar {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  font-size: 22rpx;
  color: var(--text-body);
}

.action-btn-hover {
  background: var(--bg-section);
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.remark-content {
  padding: 24rpx;
  background: var(--bg-section);
  border-radius: var(--radius-md);
  color: var(--text-body);
  font-size: 28rpx;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--bg-card);
  padding: 24rpx 32rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.btn-flex {
  flex: 1;
  margin: 0;
}

.btn-retry {
  margin-top: 32rpx;
  width: 240rpx;
}

/* ======================== */
/* 已完工展示卡片             */
/* ======================== */
.completed-card {
  border-left: 6rpx solid var(--status-success);
}

.section-label {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.photo-scroll {
  white-space: nowrap;
  width: 100%;
}

.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  margin-right: 16rpx;
  display: inline-block;
}

.signed-area {
  margin-top: 24rpx;
}

.signed-img {
  width: 100%;
  height: 200rpx;
  border-radius: var(--radius-md);
  background: var(--bg-section);
}

/* ======================== */
/* 完工弹窗                  */
/* ======================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
  max-height: 92vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-heading);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-muted);
  background: var(--bg-section);
  border-radius: 50%;
}

.modal-section {
  margin-bottom: 28rpx;
}

.modal-label {
  font-size: 28rpx;
  color: var(--text-body);
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sign-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sign-hint-sm {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 400;
}

/* 照片格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-thumb-sm {
  width: 144rpx;
  height: 144rpx;
  border-radius: var(--radius-md);
  object-fit: cover;
}

.add-photo-btn {
  width: 144rpx;
  height: 144rpx;
  background: var(--bg-section);
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 56rpx;
  color: var(--text-muted);
  line-height: 1;
}

/* 备注文本框 */
.remark-textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--bg-section);
  border-radius: var(--radius-md);
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-body);
  border: 1rpx solid var(--border-light);
}

/* 签字区 */
.sign-canvas-wrap {
  background: #fff;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 2rpx dashed #d0d0d0;
  margin-bottom: 16rpx;
}

.btn-resign-sm {
  text-align: right;
  font-size: 24rpx;
  color: var(--brand-primary);
  padding-right: 8rpx;
}

/* 底部按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--bg-section);
  color: var(--text-heading);
  font-size: 28rpx;
  border-radius: var(--radius-md);
}

.btn-submit-complete {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.35);
}
